# Docker Compose deployment variables
MYSQL_DATABASE=myway
MYSQL_USER=myway_user
MYSQL_PASSWORD=change_me_secure_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# Backend
JWT_SECRET=change_me_super_secure_jwt_secret
JWT_EXPIRATION_SECONDS=86400

# Frontend to backend API (via nginx proxy in frontend container)
VITE_API_BASE_URL=/api/v1

# Optional CORS override
CORS_ALLOWED_ORIGINS=http://localhost
